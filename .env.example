# Copy to `.env` (gitignored) and fill in. Loaded by the VS Code launch configs
# (envFile) and can be sourced for CLI runs. These override the JSON config via
# Viper's AutomaticEnv (key `email.username` ⇄ env `EMAIL_USERNAME`).

# Gmail SMTP delivery for OTP / password-reset emails.
#   EMAIL_USERNAME = your Gmail address
#   EMAIL_PASSWORD = a Google "App Password" (16 chars, NOT your normal password;
#                    requires 2-Step Verification enabled on the account)
#   EMAIL_FROM     = optional; defaults to EMAIL_USERNAME
# Gitignored — holds the Gmail SMTP secret. Fill EMAIL_PASSWORD with a Google
# App Password (16 chars, 2-Step Verification must be enabled).
ACTIVE_ENV=
STORE_SSLMODE=
CACHE_TLS=
MSGQUEUE_ENABLED=
TOKEN_PRIVATEKEYPATH=
TOKEN_PUBLICKEYPATH=
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=
STORE_HOST=
STORE_PORT=
STORE_USER=
STORE_PASSWORD=
STORE_NAME=
CACHE_HOST=
CACHE_PORT=
CACHE_PASSWORD=
